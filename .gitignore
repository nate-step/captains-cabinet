# Secrets
cabinet/.env
.oauth-backup-*.json

# Claude Code auto-memory (per-developer, not part of the framework)
.claude/memory/
.claude/scheduled_tasks.lock

# Agent definitions at .claude/agents/ are derived by the preset loader
# (copied from presets/<active>/agents/ with instance/agents/ overlays).
# Source of truth lives in presets/ and instance/agents/ — do NOT track
# the derived copies.
.claude/agents/*.md
!.claude/agents/.gitkeep

# Runtime Cabinet state assembled by cabinet/scripts/load-preset.sh
# Derived from framework/ + presets/<active>/ + instance/ on each start.
# Do not commit.

# Per-officer working directories (created at runtime for session isolation)
officers/
# Exception: CoS MCP config registers the host MCP server — ship with framework
# so every Cabinet install wires host access to CoS on boot. No secrets in file.
!officers/cos/
!officers/cos/.mcp.json

# Runtime logs
memory/logs/*.jsonl
memory/logs/*.log

# Per-officer session state (resets between runs)
instance/memory/tier2/**/.session-state.json

# Build artifacts
cabinet/dashboard/tsconfig.tsbuildinfo
cabinet/dashboard/.next/

# ============================================================
# Runtime state (layer 3 — product-specific, evolves on server)
# Protected from git pull overwriting server evolution.
# Foundation files (layer 2) are git-tracked and safe to update.
# ============================================================

# Product config (each deployment has its own)
instance/config/product.yml

# Officer working notes (accumulated at runtime)
instance/memory/tier2/**/*.md
!instance/memory/tier2/**/.gitkeep

# Experience records, decision log, research archive
memory/tier3/

# Evolved skills (created/modified by the learning loop at runtime)
memory/skills/evolved/**/*.md
!memory/skills/evolved/.gitkeep

# Shared interface content (populated by officers at runtime)
shared/interfaces/**/*.md
!shared/interfaces/**/.gitkeep

# Deployment-specific plans (not part of the generic framework)
founders-cabinet-plan.md

# Node
node_modules/

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db

# Docker volumes (managed by Docker, not git)
pgdata/
redisdata/
