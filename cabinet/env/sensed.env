# =============================================================
# Project: Sensed — Per-Project Environment Variables
# =============================================================
# These override/extend the base cabinet/.env for this project.
# Managed via: cabinet/scripts/switch-project.sh sensed

# Telegram group chat for this project's warroom
TELEGRAM_HQ_CHAT_ID=-5233594839

# Product database
NEON_CONNECTION_STRING=

# Product repo path (mounted in Docker)
PRODUCT_REPO_PATH=/opt/product

# Container naming prefix
CABINET_PREFIX=sensed
