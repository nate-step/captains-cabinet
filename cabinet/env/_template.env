# =============================================================
# Project: [PROJECT NAME] — Per-Project Environment Variables
# =============================================================
# Copy to cabinet/env/<slug>.env and fill in values.
# These override/extend the base cabinet/.env for this project.

# Telegram group chat for this project's warroom
# (Create a new Telegram group, add your officer bots, get the chat ID)
TELEGRAM_HQ_CHAT_ID=

# Product database (Neon connection string for this project)
NEON_CONNECTION_STRING=

# Product repo path on the server (will be mounted as /workspace/product)
PRODUCT_REPO_PATH=/opt/<project-name>

# Container naming prefix
CABINET_PREFIX=<project-slug>
