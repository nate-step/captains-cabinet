FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TERM=xterm-256color

# System dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    tmux \
    jq \
    unzip \
    redis-tools \
    postgresql-client \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Headless browser dependencies for Playwright/E2E testing (COO)
RUN apt-get update && apt-get install -y \
    chromium-browser \
    fonts-liberation \
    fonts-noto-color-emoji \
    libgbm1 \
    libnss3 \
    libxss1 \
    libasound2t64 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libxkbcommon0 \
    libatspi2.0-0 \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Bun (required by Channels plugin)
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Create non-root user for Claude Code
# UID 60001 + GID 60000 required for host-agent SO_PEERCRED auth (Spec 035 Phase B).
RUN groupadd -g 60000 cabinet && \
    useradd -m -s /bin/bash -u 60001 -g 60000 cabinet
USER cabinet
WORKDIR /home/cabinet

# Install Bun for cabinet user
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/home/cabinet/.bun/bin:/home/cabinet/.local/bin:${PATH}"

# Enable Claude Code 1-hour prompt cache TTL (v2.1.108+).
# Anthropic's cache silently regressed from 1h→5m in March 2026;
# this opts back into 1h. ~30-50% input token reduction.
ENV ENABLE_PROMPT_CACHING_1H=1

# Install Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash

# Install Playwright for E2E testing (COO uses this for browser automation)
RUN npx playwright install chromium

# Install MCP servers globally (instead of each officer installs them every startup)
USER root
RUN npm install -g @notionhq/notion-mcp-server @mseep/linear-mcp @neondatabase/mcp-server-neon @robinson_ai_systems/vercel-mcp
USER cabinet

# Create directories for Channels state (one per Officer)
RUN mkdir -p \
    /home/cabinet/.claude-channels/cos \
    /home/cabinet/.claude-channels/cto \
    /home/cabinet/.claude-channels/cro \
    /home/cabinet/.claude-channels/cpo

# Copy tmux config for nicer multi-pane experience
COPY --chown=cabinet:cabinet tmux.conf /home/cabinet/.tmux.conf

# Symlink start-officer.sh from mounted volume - always uses latest repo version
RUN ln -sf /opt/founders-cabinet/cabinet/scripts/start-officer.sh /home/cabinet/start-officer.sh

# Copy the entrypoint (runs as root to fix volume permissions, then drops to cabinet)
USER root
COPY scripts/entrypoint.sh /home/cabinet/entrypoint.sh
RUN chmod +x /home/cabinet/entrypoint.sh

WORKDIR /opt/founders-cabinet

ENTRYPOINT ["/home/cabinet/entrypoint.sh"]
