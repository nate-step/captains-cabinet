# =============================================================
# Sensed Cabinet — Environment Variables
# =============================================================
# Copy to .env and fill in all values. NEVER commit .env to git.

# Telegram Bot Tokens (from @BotFather)
TELEGRAM_COS_TOKEN=
TELEGRAM_CTO_TOKEN=
TELEGRAM_CRO_TOKEN=
TELEGRAM_CPO_TOKEN=

# Telegram Group & Captain
TELEGRAM_HQ_CHAT_ID=
CAPTAIN_TELEGRAM_ID=

# GitHub
GITHUB_PAT=

# Linear
LINEAR_API_KEY=

# Neon (PostgreSQL for Sensed product)
NEON_CONNECTION_STRING=

# Notion (Business Brain)
NOTION_API_KEY=

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# Mapbox (product — maps)
MAPBOX_TOKEN=

# Research APIs
PERPLEXITY_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=

# Cabinet Infrastructure (internal PostgreSQL for memory)
POSTGRES_PASSWORD=cabinet_secure_password_change_me
CABINET_PREFIX=sensed

# Claude Code (optional — only needed if NOT using Max subscription OAuth)
# If set, overrides subscription auth and bills per-token via API.
# Leave empty to use Max subscription (recommended).
ANTHROPIC_API_KEY=
