{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enableAllProjectMcpServers": true,
  "cleanupPeriodDays": 60,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "mcp__notion*",
      "mcp__linear*",
      "mcp__neon*",
      "mcp__vercel*",
      "mcp__plugin_telegram*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(docker *)",
      "Bash(systemctl *)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/pre-captain-dm.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/build-vs-buy-precheck.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/post-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_telegram_telegram__reply",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/post-reply-voice.sh"
          },
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/post-reply-memory.sh"
          },
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/captain-gate-language.sh"
          },
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/captain-posture-compliance.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/post-file-write-memory.sh"
          },
          {
            "type": "command",
            "command": "bash /opt/founders-cabinet/cabinet/scripts/hooks/personal-work-parity.sh"
          }
        ]
      }
    ]
  }
}
